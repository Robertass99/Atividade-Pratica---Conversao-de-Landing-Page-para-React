<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <!-- Fundo circular -->
  <circle cx="50" cy="50" r="50" fill="#0d6efd"/>
  
  <!-- Rosto -->
  <circle cx="50" cy="45" r="35" fill="#fff"/>
  
  <!-- Olho esquerdo -->
  <circle cx="35" cy="35" r="4" fill="#0d6efd"/>
  
  <!-- Olho direito -->
  <circle cx="65" cy="35" r="4" fill="#0d6efd"/>
  
  <!-- Sorriso (arco) -->
  <path d="M 35 50 Q 50 65 65 50" stroke="#0d6efd" stroke-width="3" fill="none" stroke-linecap="round"/>
  
  <!-- Dente central -->
  <rect x="48" y="50" width="4" height="8" fill="#0d6efd"/>
</svg>
